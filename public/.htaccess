# =========================================================================
# OnlineProjectPlanner – Browser Cache Control
# =========================================================================
# These rules prevent stale JavaScript / CSS from being served after an
# update.  HTML pages are never cached so the browser always fetches the
# latest markup (which contains cache-busting ?v= query strings for
# JS/CSS assets).
# =========================================================================

<IfModule mod_headers.c>
  # HTML – always revalidate (ensures the latest ?v= cache-busters are used)
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # JS / CSS – revalidate on every request (ETag/Last-Modified still work)
  <FilesMatch "\.(js|css)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>

  # JSON (version.json etc.) – never cache
  <FilesMatch "\.json$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
</IfModule>

# Fallback: use mod_expires if mod_headers is not available
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType application/json "access plus 0 seconds"
  ExpiresByType text/css "access plus 0 seconds"
  ExpiresByType application/javascript "access plus 0 seconds"
</IfModule>
